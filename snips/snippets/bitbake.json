{
    "bitbake-template": {
        "prefix": "bb-autotools",
        "body": [
            "# Copyright (C) ${1:2026} ${2:Lysander Lyu} <${3:your.email@example.com}>",
            "# Released under the ${4:MIT} license",
            "",
            "SUMMARY = \"${5:Brief description of your package}\"",
            "DESCRIPTION = \"${6:Longer description of what your package does and its features}\"",
            "HOMEPAGE = \"${7:https://example.com/project}\"",
            "LICENSE = \"${8:MIT}\"",
            "LIC_FILES_CHKSUM = \"file://LICENSE;md5=${9:1234567890abcdef1234567890abcdef}\"",
            "",
            "# Source URI and checksums",
            "SRC_URI = \"${10:https://example.com/releases/${PN}-${PV}.tar.gz}\"",
            "SRC_URI[sha256sum] = \"${11:abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890}\"",
            "",
            "# Version handling",
            "PV = \"${12:1.0.0}\"",
            "# For git repositories:",
            "# SRC_URI = \"git://example.com/repo.git;protocol=https;branch=main\"",
            "# SRCREV = \"${AUTOREV}\"",
            "# PV = \"${@d.getVar('SRCREV', True)[:8]}\"",
            "",
            "S = \"\\${WORKDIR\\}/git\"",
            "# Dependencies",
            "DEPENDS = \"${13:zlib virtual/libiconv}\"",
            "RDEPENDS:\\${PN\\} = \" libgcc1\"",
            "",
            "# Build configuration",
            "inherit ${15:autotools pkgconfig}",
            "",
            "# Additional configuration options (if needed)",
            "EXTRA_OECONF += \" --disable-static --enable-shared\"",
            "",
            "# Installation configuration",
            "do_install_append() {",
            "    # Custom installation steps if needed",
            "    install -d ${D}${sysconfdir}",
            "    install -m 0644 ${WORKDIR}/config.conf ${D}${sysconfdir}/",
            "}",
            "",
            "# Extra tasks (if needed)",
            "do_compile_prepend() {",
            "    # Pre-compilation steps",
            "    echo \"Pre-compiling ${PN}\"",
            "}",
            ""
        ],
        "description": "BitBake recipe template"
    },
    
    "bitbake-minimal": {
        "prefix": "bb-min",
        "body": [
            "# ${1:Package Name} recipe",
            "",
            "SUMMARY = \"${2:Package summary}\"",
            "LICENSE = \"${3:MIT}\"",
            "LIC_FILES_CHKSUM = \"file://LICENSE;md5=${4:checksum}\"",
            "",
            "SRC_URI = \"${5:https://example.com/package-${PV}.tar.gz}\"",
            "SRC_URI[sha256sum] = \"${6:sha256checksum}\"",
            "",
            "inherit ${7:autotools}",
            "",
            "# Package version",
            "PV = \"${8:1.0.0}\""
        ],
        "description": "Minimal BitBake recipe template"
    },
    
    "bitbake-full-recipe": {
        "prefix": "bb-custombuild",
        "body": [
            "# Copyright (C) ${1:2026} ${2:Lysander Lyu} <${3:your.email@example.com}>",
            "# Released under the ${4:MIT} license",
            "",
            "SUMMARY = \"${5:Brief description of your package}\"",
            "DESCRIPTION = \"${6:Longer description of what your package does and its features}\"",
            "HOMEPAGE = \"${7:https://example.com/project}\"",
            "LICENSE = \"${8:MIT}\"",
            "LIC_FILES_CHKSUM = \"file://LICENSE;md5=${9:1234567890abcdef1234567890abcdef}\"",
            "",
            "SRC_URI = \"${10:https://example.com/releases/${PN}-${PV}.tar.gz}\"",
            "SRC_URI[sha256sum] = \"${11:abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890}\"",
            "",
            "PV = \"${12:1.0.0}\"",
            "",
            "DEPENDS = \"${13:zlib virtual/libiconv}\"",
            "RDEPENDS:\\${PN\\} = \"${14:libgcc1}\"",
            "",
            "",
            "# Build configuration",
            "EXTRA_OECONF += \" --disable-static --enable-shared\"",
            "",
            "# Custom build functions",
            "do_compile() {",
            "    ${21:# Compile commands}",
            "    oe_runmake ${22:ARGS}",
            "}",
            "",
            "do_configure() {",
            "    ${23:# Configure commands}",
            "    oe_runconf ${24:ARGS}",
            "}",
            "",
            "do_install() {",
            "    ${25:# Install commands}",
            "    oe_runmake install DESTDIR=${D}",
            "}",
            "",
            "# Installation configuration",
            "do_install_append() {",
            "    # Custom installation steps if needed",
            "    install -d ${D}${sysconfdir}",
            "    install -m 0644 ${WORKDIR}/config.conf ${D}${sysconfdir}/",
            "}"
        ],
        "description": "Complete BitBake recipe with all build functions"
    },
    
    "bitbake-ssh-git": {
        "prefix": "src-ssh-git",
        "body": [
            "# SSH Git repository source",
            "PV = \"${4:${@d.getVar('SRCREV', True)[:8]}}\"",
            "SRC_URI = \"${1:git://git@github.com/username/repo.git;protocol=ssh;branch=${2:main}}\"",
            "SRCREV = \"${3:\\${AUTOREV}}\"",
            "S = \"\\${WORKDIR\\}/git\"",
            "# For https with ssh keys:",
            "# SRC_URI = \"${5:git://github.com/username/repo.git;protocol=https;user=git}\"",
            "# SRCREV = \"${6:\\${AUTOREV}}\"",
            "# PV = \"${7:${@d.getVar('SRCREV', True)[:8]}}\""
        ],
        "description": "SSH Git repository source URI for BitBake"
    },
    
    "bitbake-https-git": {
        "prefix": "src-https-git",
        "body": [
            "# HTTPS Git repository source",
            "PV = \"${4:${@d.getVar('SRCREV', True)[:8]}}\"",
            "SRC_URI = \"${1:git://github.com/username/repo.git;protocol=https;branch=${2:main}}\"",
            "SRCREV = \"${3:\\${AUTOREV}}\"",
            "S = \"\\${WORKDIR\\}/git\"",
            "# For https with token authentication:",
            "# SRC_URI = \"${5:https://token@github.com/username/repo.git;protocol=https;branch=${6:main}}\"",
            "# SRCREV = \"${7:autorev}\"",
            "# PV = \"${8:${@d.getVar('SRCREV', True)[:8]}}\""
        ],
        "description": "HTTPS Git repository source URI for BitBake"
    },
    
    "bitbake-ssh-git-with-submodules": {
        "prefix": "src-ssh-git-sub",
        "body": [
            "# SSH Git repository with submodules",
            "PV = \"${4:${@d.getVar('SRCREV', True)[:8]}}\"",
            "SRC_URI = \"${1:git://git@github.com/username/repo.git;protocol=ssh;branch=${2:main}}\"",
            "SRCREV = \"${3:\\${AUTOREV}}\"",
            "# Enable submodules for SSH git repos",
            "S = \"${WORKDIR}/git\"",
            "# Additional configuration for submodules",
            "# do_configure_prepend() {",
            "#     git submodule update --init --recursive",
            "# }"
        ],
        "description": "SSH Git repository with submodules for BitBake"
    },
    "bitbake-src-wget": {
        "prefix": "src-wget",
        "body": [
            "# Source from wget (common pattern)",
            "SRC_URI = \"${1:https://example.com/${PN}-${PV}.tar.gz}\"",
            "SRC_URI[sha256sum] = \"${2:abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890}\"",
            "# Alternative patterns:",
            "# SRC_URI = \"${3:http://ftp.gnu.org/gnu/${PN}/${PN}-${PV}.tar.gz}\"",
            "# SRC_URI[sha256sum] = \"${4:abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890}\""
        ],
        "description": "wget source URI pattern for BitBake"
    },
    
    "bitbake-src-wget-multiple": {
        "prefix": "src-wget-multi",
        "body": [
            "# Multiple wget sources",
            "SRC_URI = \"${1:https://example.com/${PN}-${PV}.tar.gz} \\",
            "           ${2:https://example.com/${PN}-${PV}-extra.tar.gz}\"",
            "SRC_URI[sha256sum] = \"${3:abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890} \\",
            "                    ${4:abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890}\""
        ],
        "description": "Multiple wget sources for BitBake"
    },
    
    "bitbake-src-wget-with-patches": {
        "prefix": "src-wget-patches",
        "body": [
            "# wget source with patches",
            "SRC_URI = \"${1:https://example.com/${PN}-${PV}.tar.gz} \\",
            "           file://0001-fix-build.patch \\",
            "           file://0002-add-feature.patch\"",
            "SRC_URI[sha256sum] = \"${2:abcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890}\"",
            "# Patches should be placed in ${WORKDIR} or ${S}/patches/"
        ],
        "description": "wget source with patches for BitBake"
    },
    
    "bitbake-src-wget-full": {
        "prefix": "src-wget-full",
        "body": [
            "# Copyright (C) ${1:2026} ${2:Lysander Lyu} <${3:your.email@example.com}>",
            "# Released under the ${4:MIT} license",
