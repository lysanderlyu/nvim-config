  "RCC Driver Template": {
    "prefix": "rcc_template",
    "body": [
      "// ==========================================",
      "// RCC Peripheral Driver Interface (Device Model)",
      "// ==========================================",
      "",
      "#ifndef RCC_DRIVER_H",
      "#define RCC_DRIVER_H",
      "",
      "#include \"device.h\"",
      "#include \"stm32f10x.h\"",
      "#include <stdint.h>",
      "",
      "/* Error Codes */",
      "#define RCC_OK               0x00",
      "#define RCC_ERR_INVALID_CLK  0x01",
      "#define RCC_ERR_TIMEOUT      0x02",
      "#define RCC_ERR_BUSY         0x03",
      "",
      "/* Clock Source Definitions */",
      "typedef enum {",
      "    RCC_CLK_HSE = 0,",
      "    RCC_CLK_HSI,",
      "    RCC_CLK_LSE,",
      "    RCC_CLK_LSI,",
      "    RCC_CLK_PLL",
      "} rcc_clock_source_t;",
      "",
      "/* Peripheral Clock Enable Masks */",
      "typedef enum {",
      "    RCC_PERIPH_GPIO_A = 0,",
      "    RCC_PERIPH_GPIO_B,",
      "    RCC_PERIPH_USART1,",
      "    /* Add more as needed */",
      "} rcc_peripheral_t;",
      "",
      "/* System Clock Configuration Structure */",
      "typedef struct {",
      "    rcc_clock_source_t source;      // Main system clock source",
      "    uint32_t sys_clk_freq_hz;       // Target frequency",
      "    uint8_t ahb_prescaler;          // /1, /2, /4...",
      "    uint8_t apb1_prescaler;",
      "    uint8_t apb2_prescaler;",
      "} rcc_sys_config_t;",
      "",
      "/* Forward declaration */",
      "struct rcc_device;",
      "",
      "/* RCC Driver Operations (ops table) */",
      "typedef struct rcc_ops {",
      "    int  (*configure_system_clock)(struct rcc_device*, const rcc_sys_config_t*);",
      "    void (*reset_all_peripherals)(struct rcc_device*);",
      "    int  (*enable_clock)(struct rcc_device*, rcc_peripheral_t peripheral);",
      "    int  (*disable_clock)(struct rcc_device*, rcc_peripheral_t peripheral);",
      "    uint8_t  (*is_source_ready)(struct rcc_device*, rcc_clock_source_t source);",
      "    uint32_t (*get_system_frequency)(struct rcc_device*);",
      "} rcc_ops_t;",
      "",
      "/* RCC Device Structure */",
      "typedef struct rcc_device {",
      "    device_t dev;             // Base device",
      "    RCC_TypeDef *port;",
      "    const rcc_ops_t* ops;     // Driver operations",
      "    volatile uint32_t status_reg;",
      "} rcc_device_t;",
      "",
      "#endif /* RCC_DRIVER_H */"
    ],
    "description": "Complete function list and skeleton for an RCC driver module (Clock control, reset, peripheral enablement)"
  },
  "I2C Driver Template": {
    "prefix": "i2c_template",
    "body": [
      "// ==========================================",
      "// I2C Peripheral Driver Interface",
      "// ==========================================",
      "",
      "#ifndef I2C_DRIVER_H",
      "#define I2C_DRIVER_H",
      "",
      "#include <stdint.h>",
      "#include <stddef.h>",
      "",
      "/* Error Codes */",
      "#define I2C_OK                0x00",
      "#define I2C_ERR_BUSY          0x01",
      "#define I2C_ERR_TIMEOUT       0x02",
      "#define I2C_ERR_NACK          0x03",
      "",
      "/* Configuration Structure */",
      "typedef struct {",
      "\tuint8_t sda_pin;",
      "\tuint8_t scl_pin;",
      "\tuint8_t speed_mode;     // e.g., I2C_SPEED_STANDARD, I2C_SPEED_FAST",
      "\tuint32_t timeout_ms;",
      "} i2c_config_t;",
      "",
      "/* Driver Handle (Optional for state management) */",
      "typedef struct {",
      "\ti2c_config_t config;",
      "\tvoid* hw_handle;        // MCU specific handle pointer",
      "} i2c_handle_t;",
      "",
      "/* Initialization */",
      "// Returns I2C_OK on success, error code otherwise.",
      "int i2c_init(i2c_config_t *cfg);",
      "void i2c_deinit(void);",
      "",
      "/* Basic Communication */",
      "int i2c_write_byte(uint8_t slave_addr, uint8_t data);",
      "int i2c_read_byte(uint8_t slave_addr, uint8_t* out_data);",
      "",
      "/* Block Transfer (Common for Sensors) */",
      "int i2c_write_reg(uint8_t slave_addr, uint8_t reg_addr, const uint8_t* data, uint16_t length);",
      "int i2c_read_reg(uint8_t slave_addr, uint8_t reg_addr, uint8_t* out_data, uint16_t length);",
      "",
      "#endif /* I2C_DRIVER_H */"
    ],
    "description": "Complete function list and skeleton for an I2C driver module"
  },

