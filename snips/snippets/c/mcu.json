  "GPIO Driver Template": {
    "prefix": "gpio_template",
    "body": [
      "// ==========================================",
      "// GPIO Peripheral Driver Interface",
      "// ==========================================",
      "",
      "#ifndef GPIO_DRIVER_H",
      "#define GPIO_DRIVER_H",
      "",
      "#include \"device.h\"",
      "#include \"stm32f10x.h\"",
      "",
      "/* GPIO IO Mode */",
      "typedef enum {",
      "    GPIO_MODE_INPUT,",
      "    GPIO_MODE_OUTPUT,",
      "    GPIO_MODE_AF,",
      "    GPIO_MODE_ANALOG",
      "} gpio_mode_t;",
      "",
      "typedef enum {",
      "    GPIO_OUTPUT_PP,",
      "    GPIO_OUTPUT_OD",
      "} gpio_output_type_t;",
      "",
      "typedef enum {",
      "    GPIO_NO_PULL,",
      "    GPIO_PULL_UP,",
      "    GPIO_PULL_DOWN",
      "} gpio_pull_t;",
      "",
      "/* GPIO Edge Type */",
      "typedef enum {",
      "    GPIO_EDGE_RISING  = 1 << 0,",
      "    GPIO_EDGE_FALLING = 1 << 1,",
      "} gpio_edge_type;",
      "",
      "/* GPIO Speed */",
      "typedef enum {",
      "    GPIO_SPEED_LOW,",
      "    GPIO_SPEED_HIGH,",
      "} gpio_speed_t;",
      "",
      "typedef void (*gpio_irq_handler_t)(void* arg);",
      "",
      "/* Configuration Structure */",
      "typedef struct {",
      "    GPIO_TypeDef *port;             // The GPIO port e.g. GPIOA",
      "    uint16_t pin;                   // Pin",
      "    gpio_mode_t mode;               // INPUT, OUTPUT, AF, ANALOG",
      "    gpio_pull_t pull;               // PULL_UP, PULL_DOWN, NO_PULL",
      "    gpio_output_type_t output_type; // PP or OD or NP(No Pull)",
      "    gpio_speed_t output_speed;      // LOW_SPEED, HIGH_SPEED (for outputs)",
      "} gpio_config_t;",
      "",
      "struct gpio_device;",
      "",
      "/* GPIO Device Handle */",
      "typedef struct gpio_ops {",
      "    void (*write)(struct gpio_device*, int);",
      "    int  (*read)(struct gpio_device*);",
      "    void (*toggle)(struct gpio_device*);",
      "    /* Initialization */",
      "    int (*init)(struct gpio_device *gpio, const gpio_config_t *cfg);",
      "    void (*set_mode)(struct gpio_device *gpio, gpio_mode_t mode);",
      "    void (*deinit)(struct gpio_device *gpio);",
      "    /* Interrupts */",
      "    int (*enable_interrupt)(struct gpio_device *gpio, gpio_edge_type edge, gpio_irq_handler_t handler, void* arg);",
      "    void (*disable_interrupt)(struct gpio_device *gpio);",
      "    void (*clear_interrupt_flag)(struct gpio_device *gpio);",
      "} gpio_ops_t;",
      "",
      "/* Device Model */",
      "typedef struct {",
      "    device_t dev;",
      "    GPIO_TypeDef* port;",
      "    uint16_t pin;",
      "    const gpio_ops_t *ops;",
      "} gpio_device_t;",
      "",
      "#endif /* GPIO_DRIVER_H */"
    ],
    "description": "Complete function list and skeleton for a GPIO driver module"
  },
