  "USB Driver Template": {
    "prefix": "usb_template",
    "body": [
      "// ==========================================",
      "// USB Peripheral Driver Interface",
      "// ==========================================",
      "",
      "#ifndef USB_DRIVER_H",
      "#define USB_DRIVER_H",
      "",
      "#include <stdint.h>",
      "#include <stddef.h>",
      "",
      "/* Error Codes */",
      "#define USB_OK                0x00",
      "#define USB_ERR_NOT_ATTACHED  0x01",
      "#define USB_ERR_NO_MEMORY     0x02",
      "#define USB_ERR_TIMEOUT       0x03",
      "",
      "/* Speed Definitions */",
      "#define USB_SPEED_FULL        0x00 // 12 Mbps (Full Speed)",
      "#define USB_SPEED_HIGH        0x01 // 480 Mbps (High Speed - if supported)",
      "",
      "/* Endpoint Types */",
      "#define USB_EP_TYPE_CONTROL   0x00",
      "#define USB_EP_TYPE_BULK      0x02",
      "#define USB_EP_TYPE_INTERRUPT 0x03",
      "#define USB_EP_TYPE_ISOCHRONOUS 0x04",
      "",
      "/* Device Configuration Structure */",
      "typedef struct {",
      "\tuint8_t speed;            // USB_SPEED_FULL or HIGH",
      "\tconst char *vendor_name;",
      "\tconst char *product_name;",
      "\tuint16_t vendor_id;",
      "\tuint16_t product_id;",
      "\tuint8_t max_power_ma;     // Max current in mA (e.g., 500)",
      "} usb_device_config_t;",
      "",
      "/* Endpoint Configuration Structure */",
      "typedef struct {",
      "\tuint8_t ep_addr;          // Address: 0x01 to 0x7F (Out) or 0x81-0xFF (In)",
      "\tuint8_t type;             // Control, Bulk, Interrupt, Isochronous",
      "\tuint32_t max_packet_size; // MTU (e.g., 64 for Full Speed)",
      "\tvoid *rx_buffer;          // Pointer to RX buffer (for interrupts/bulk)",
      "\tsize_t rx_buffer_len;     // Length of RX buffer",
      "} usb_endpoint_cfg_t;",
      "",
      "/* Global Handle/State */",
      "typedef struct {",
      "\tusb_device_config_t config;",
      "\tuint8_t num_endpoints;",
      "\tconst usb_endpoint_cfg_t *endpoints;",
      "} usb_handle_t;",
      "",
      "/* Initialization & Enumeration */",
      "// Initialize USB peripheral and start enumeration.",
      "// Returns 0 on success, error code otherwise.",
      "int usb_init(const usb_device_config_t *cfg);",
      "void usb_deinit(void);",
      "uint8_t usb_get_status(void); // Returns: ATTACHED, CONFIGURED, SUSPENDED",
      "",
      "/* Endpoint Management */",
      "// Register endpoints before calling init.",
      "int usb_configure_endpoint(const usb_endpoint_cfg_t *cfg);",
      "void usb_enable_all_endpoints(void);",
      "",
      "/* Control Transfers (Standard Requests) */",
      "// Handle standard USB requests like GET_DESCRIPTOR, SET_ADDRESS.",
      "// Override this in your application to handle custom class commands.",
      "int usb_handle_setup_packet(const uint8_t *setup_pkt, uint8_t **data_ptr, size_t *len);",
      "",
      "/* Bulk/Interrupt Transfers (Data I/O) */",
      "// Send data on a specific endpoint address.",
      "int usb_write(uint8_t ep_addr, const void *data, size_t len, uint32_t timeout_ms);",
      "// Read data from a specific endpoint address (blocking or polling).",
      "int usb_read(uint8_t ep_addr, void *buffer, size_t max_len, uint32_t *actual_len, uint32_t timeout_ms);",
      "",
      "/* Callbacks for User Application */",
      "// Implement these in your main.c to handle specific device logic.",
      "// Called when a standard setup request is received but not handled by the core.",
      "void usb_on_class_request(uint8_t *data, size_t len);",
      "",
      "#endif /* USB_DRIVER_H */"
    ],
    "description": "USB Driver with Config Structs for Device and Endpoints"
  },
  "Timer Driver Template": {
    "prefix": "timer_template",
    "body": [
      "// ==========================================",
      "// Timer Peripheral Driver Interface",
      "// ==========================================",
      "",
      "#ifndef TIMER_DRIVER_H",
      "#define TIMER_DRIVER_H",
      "",
      "#include <stdint.h>",
      "#include <stddef.h>",
      "#include <stdbool.h>",
      "",
      "/* Error Codes */",
      "#define TIMER_OK                0x00",
      "#define TIMER_ERR_BUSY          0x01",
      "#define TIMER_ERR_OVERFLOW      0x02",
      "",
      "/* Timer Modes */",
      "#define TIMER_MODE_COUNTER      0x00 // Up/Down counting",
      "#define TIMER_MODE_ONE_SHOT     0x01 // Count once then stop",
      "#define TIMER_MODE_PWM          0x02 // PWM Output",
      "#define TIMER_MODE_CAPTURE      0x03 // Input Capture (Edge timing)",
      "",
      "/* General Timer Configuration */",
      "typedef struct {",
      "\tuint32_t clock_source_hz;   // Source frequency (e.g., APB1, PLL)",
      "\tuint32_t prescaler;         // Prescaler value (divides clock), 0 = /1",
      "\tuint32_t period;            // Auto-reload value (max count)",
      "\tbool repeat_mode;           // True for continuous loop, False for one-shot",
      "} timer_config_t;",
      "",
      "/* PWM Configuration */",
      "typedef struct {",
      "\tuint8_t channel;            // Channel ID (e.g., 1, 2, 3, 4)",
      "\tbool active_high;           // True: High=ON, False: Low=ON (Active Low)",
      "\tuint16_t duty_cycle_pct;    // Duty cycle percentage (0-100)",
      "} pwm_config_t;",
      "",
      "/* Handle Structure */",
      "typedef struct {",
      "\ttimer_config_t config;",
      "\tvoid (*callback)(void);     // User callback on overflow/compare",
      "\tbool is_running;",
      "} timer_handle_t;",
      "",
      "/* Initialization & Control */",
      "// Initialize the timer with general settings.",
      "// Returns 0 on success, error code otherwise.",
      "int timer_init(const timer_config_t *cfg);",
      "void timer_start(void);       // Start counting from current position",
      "void timer_restart(void);     // Reset counter to 0 and start",
      "void timer_stop(void);        // Halt the timer",
      "void timer_deinit(void);      // Release resources and reset registers",
      "",
      "/* Timing Operations */",
      "// Set a new delay period without re-initializing.",
      "int timer_set_period(uint32_t ticks_ms);  // Sets auto-reload based on ms",
      "",
      "/* PWM Generation */",
      "// Configure and start PWM on a specific channel.",
      "int timer_pwm_start(const pwm_config_t *cfg);",
      "void timer_pwm_stop(void);                // Stop all PWM outputs",
      "void timer_pwm_set_duty(uint8_t channel, uint16_t duty_pct); // Dynamic update",
      "",
      "/* Input Capture (Optional) */",
      "// Enable capture on a specific input pin.",
      "int timer_capture_enable(uint8_t channel, void (*on_edge)(uint32_t time));",
      "void timer_capture_disable(uint8_t channel);",
      "",
      "/* Status & Callbacks */",
      "bool timer_is_running(void);",
      "uint32_t timer_get_counter(void);         // Current count value",
      "uint32_t timer_get_elapsed_ms(void);      // Time since last start/restart (approx)",
      "",
      "#endif /* TIMER_DRIVER_H */"
    ],
    "description": "Timer Driver with Config Structs for General Purpose and PWM"
  },
  "LCD Driver Template": {
