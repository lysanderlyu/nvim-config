      "// ==========================================",
      "// LCD Peripheral Driver Interface (with Page Support)",
      "// ==========================================",
      "",
      "#ifndef LCD_DRIVER_H",
      "#define LCD_DRIVER_H",
      "",
      "#include <stdint.h>",
      "#include <stddef.h>",
      "#include <stdbool.h>",
      "",
      "/* Error Codes */",
      "#define LCD_OK                0x00",
      "#define LCD_ERR_BUSY          0x01",
      "#define LCD_ERR_TIMEOUT       0x02",
      "#define LCD_ERR_INVALID_PARAM 0x03",
      "",
      "/* Display Configuration */",
      "#define LCD_LINES             4",
      "#define LCD_COLS              20",
      "#define LCD_CHAR_MAP_SIZE     8",
      "#define LCD_PAGE_MAX_COUNT    5 // Max number of logical pages supported",
      "",
      "/* Custom Character Structure */",
      "typedef struct {",
      "\tuint8_t char_code;        // Index in CGRAM (e.g., 0 to 7)",
      "\tconst uint8_t bitmap[8];  // 5x8 or 5x10 pixel data array",
      "} lcd_custom_char_t;",
      "",
      "/* Image Structure */",
      "typedef struct {",
      "\tuint8_t width;            // Width in pixels (typically 5)",
      "\tuint8_t height;           // Height in pixels (e.g., 8, 16)",
      "\tconst uint8_t* data;      // Pointer to raw bitmap data array",
      "} lcd_image_t;",
      "",
      "/* Page Content Structure */",
      "// Defines the content for a single logical page",
      "typedef struct {",
      "\tchar title[17];           // Title string (max 16 chars + null)",
      "\tconst char* lines[LCD_LINES]; // Array of text strings to display",
