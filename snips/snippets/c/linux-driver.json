  "SDIO Driver Skeleton": {
    "prefix": "sdiodrv",
    "body": [
      "#include <linux/module.h>",
      "#include <linux/mmc/sdio_func.h>",
      "#include <linux/mmc/sdio_ids.h>",
      "",
      "struct ${1:mysdio}_data {",
      "\tstruct sdio_func *func;",
      "};",
      "",
      "static int ${1:mysdio}_probe(struct sdio_func *func, const struct sdio_device_id *id)",
      "{",
      "\tstruct ${1:mysdio}_data *data;",
      "\tint ret;",
      "",
      "\tdata = devm_kzalloc(&func->dev, sizeof(*data), GFP_KERNEL);",
      "\tif (!data)",
      "\t\treturn -ENOMEM;",
      "",
      "\tdata->func = func;",
      "\tsdio_set_drvdata(func, data);",
      "",
      "\tsdio_claim_host(func);",
      "\tret = sdio_enable_func(func);",
      "\tsdio_release_host(func);",
      "\tif (ret)",
      "\t\treturn ret;",
      "",
      "\t// TODO: init device",
      "",
      "\treturn 0;",
      "}",
      "",
      "static void ${1:mysdio}_remove(struct sdio_func *func)",
      "{",
      "\tsdio_claim_host(func);",
      "\tsdio_disable_func(func);",
      "\tsdio_release_host(func);",
      "}",
      "",
      "static const struct sdio_device_id ${1:mysdio}_ids[] = {",
      "\t{ SDIO_DEVICE(${2:0x1234}, ${3:0x5678}) },",
      "\t{ }",
      "};",
      "MODULE_DEVICE_TABLE(sdio, ${1:mysdio}_ids);",
      "",
      "static struct sdio_driver ${1:mysdio}_driver = {",
      "\t.name = \"${1:mysdio}\",",
      "\t.id_table = ${1:mysdio}_ids,",
      "\t.probe = ${1:mysdio}_probe,",
      "\t.remove = ${1:mysdio}_remove,",
      "};",
      "",
      "module_sdio_driver(${1:mysdio}_driver);",
      "",
      "MODULE_LICENSE(\"GPL\");",
      "MODULE_AUTHOR(\"${4:Your Name}\");",
      "MODULE_DESCRIPTION(\"SDIO Driver\");"
    ],
    "description": "Linux SDIO driver skeleton"
  },
  "Network Driver Skeleton": {
    "prefix": "netdrv",
    "body": [
      "#include <linux/module.h>",
      "#include <linux/netdevice.h>",
      "",
      "struct ${1:mynet}_priv {",
      "\tstruct net_device *ndev;",
      "};",
      "",
      "static int ${1:mynet}_open(struct net_device *ndev)",
      "{",
      "\tnetif_start_queue(ndev);",
      "\treturn 0;",
      "}",
      "",
      "static int ${1:mynet}_stop(struct net_device *ndev)",
      "{",
      "\tnetif_stop_queue(ndev);",
      "\treturn 0;",
      "}",
      "",
      "static netdev_tx_t ${1:mynet}_start_xmit(struct sk_buff *skb, struct net_device *ndev)",
      "{",
      "\t// TODO: send packet",
      "\tdev_kfree_skb(skb);",
      "\treturn NETDEV_TX_OK;",
      "}",
      "",
      "static const struct net_device_ops ${1:mynet}_ops = {",
      "\t.ndo_open = ${1:mynet}_open,",
      "\t.ndo_stop = ${1:mynet}_stop,",
      "\t.ndo_start_xmit = ${1:mynet}_start_xmit,",
      "};",
      "",
      "static void ${1:mynet}_setup(struct net_device *ndev)",
      "{",
      "\tndev->netdev_ops = &${1:mynet}_ops;",
      "}",
      "",
      "static int __init ${1:mynet}_init(void)",
      "{",
      "\tstruct net_device *ndev;",
      "",
      "\tndev = alloc_netdev(0, \"eth%d\", NET_NAME_UNKNOWN, ${1:mynet}_setup);",
      "\tif (!ndev)",
      "\t\treturn -ENOMEM;",
      "",
      "\treturn register_netdev(ndev);",
      "}",
      "",
      "static void __exit ${1:mynet}_exit(void)",
      "{",
      "\t// TODO: unregister",
      "}",
      "",
      "module_init(${1:mynet}_init);",
      "module_exit(${1:mynet}_exit);",
      "",
      "MODULE_LICENSE(\"GPL\");",
      "MODULE_AUTHOR(\"${2:Your Name}\");",
      "MODULE_DESCRIPTION(\"Network Driver\");"
    ],
    "description": "Linux network driver skeleton"
  },

