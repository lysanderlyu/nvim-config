{
  "I2C Driver Skeleton": {
    "prefix": "i2cdrv",
    "body": [
      "#include <linux/module.h>",
      "#include <linux/i2c.h>",
      "",
      "struct ${1:myi2c}_data {",
      "\tstruct i2c_client *client;",
      "};",
      "",
      "static int ${1:myi2c}_probe(struct i2c_client *client, const struct i2c_device_id *id)",
      "{",
      "\tstruct ${1:myi2c}_data *data;",
      "",
      "\tdata = devm_kzalloc(&client->dev, sizeof(*data), GFP_KERNEL);",
      "\tif (!data)",
      "\t\treturn -ENOMEM;",
      "",
      "\tdata->client = client;",
      "\ti2c_set_clientdata(client, data);",
      "",
      "\t// TODO: init device",
      "",
      "\treturn 0;",
      "}",
      "",
      "static int ${1:myi2c}_remove(struct i2c_client *client)",
      "{",
      "\treturn 0;",
      "}",
      "",
      "static const struct of_device_id ${1:myi2c}_of_match[] = {",
      "\t{ .compatible = \"${2:vendor,myi2c}\" },",
      "\t{ }",
      "};",
      "MODULE_DEVICE_TABLE(of, ${1:myi2c}_of_match);",
      "",
      "static const struct i2c_device_id ${1:myi2c}_id[] = {",
      "\t{ \"${1:myi2c}\", 0 },",
      "\t{ }",
      "};",
      "MODULE_DEVICE_TABLE(i2c, ${1:myi2c}_id);",
      "",
      "static struct i2c_driver ${1:myi2c}_driver = {",
      "\t.driver = {",
      "\t\t.name = \"${1:myi2c}\",",
      "\t\t.of_match_table = ${1:myi2c}_of_match,",
      "\t},",
      "\t.probe = ${1:myi2c}_probe,",
      "\t.remove = ${1:myi2c}_remove,",
      "\t.id_table = ${1:myi2c}_id,",
      "};",
      "",
      "module_i2c_driver(${1:myi2c}_driver);",
      "",
      "MODULE_LICENSE(\"GPL\");",
      "MODULE_AUTHOR(\"${3:Your Name}\");",
      "MODULE_DESCRIPTION(\"I2C Driver\");"
    ],
    "description": "Linux I2C driver skeleton"
  },

  "GPIO Platform Driver Skeleton": {
    "prefix": "gpiodrv",
    "body": [
      "#include <linux/module.h>",
      "#include <linux/platform_device.h>",
      "#include <linux/gpio/driver.h>",
      "",
      "struct ${1:mygpio}_data {",
      "\tstruct gpio_chip chip;",
      "};",
      "",
      "static int ${1:mygpio}_direction_output(struct gpio_chip *chip, unsigned int offset, int value)",
      "{",
      "\treturn 0;",
      "}",
      "",
      "static int ${1:mygpio}_get(struct gpio_chip *chip, unsigned int offset)",
      "{",
      "\treturn 0;",
      "}",
      "",
      "static void ${1:mygpio}_set(struct gpio_chip *chip, unsigned int offset, int value)",
      "{",
      "}",
      "",
      "static int ${1:mygpio}_probe(struct platform_device *pdev)",
      "{",
      "\tstruct ${1:mygpio}_data *data;",
      "",
      "\tdata = devm_kzalloc(&pdev->dev, sizeof(*data), GFP_KERNEL);",
      "\tif (!data)",
      "\t\treturn -ENOMEM;",
      "",
      "\tdata->chip.label = dev_name(&pdev->dev);",
      "\tdata->chip.parent = &pdev->dev;",
      "\tdata->chip.owner = THIS_MODULE;",
      "",
      "\tdata->chip.direction_output = ${1:mygpio}_direction_output;",
      "\tdata->chip.get = ${1:mygpio}_get;",
      "\tdata->chip.set = ${1:mygpio}_set;",
      "",
      "\tdata->chip.base = -1;",
      "\tdata->chip.ngpio = ${2:32};",
      "",
      "\treturn devm_gpiochip_add_data(&pdev->dev, &data->chip, data);",
      "}",
      "",
      "static int ${1:mygpio}_remove(struct platform_device *pdev)",
      "{",
      "\treturn 0;",
      "}",
      "",
      "static const struct of_device_id ${1:mygpio}_of_match[] = {",
      "\t{ .compatible = \"${3:vendor,mygpio}\" },",
      "\t{ }",
      "};",
      "MODULE_DEVICE_TABLE(of, ${1:mygpio}_of_match);",
      "",
      "static struct platform_driver ${1:mygpio}_driver = {",
      "\t.probe = ${1:mygpio}_probe,",
      "\t.remove = ${1:mygpio}_remove,",
      "\t.driver = {",
      "\t\t.name = \"${1:mygpio}\",",
      "\t\t.of_match_table = ${1:mygpio}_of_match,",
      "\t},",
      "};",
      "",
      "module_platform_driver(${1:mygpio}_driver);",
      "",
      "MODULE_LICENSE(\"GPL\");",
      "MODULE_AUTHOR(\"${4:Your Name}\");",
      "MODULE_DESCRIPTION(\"GPIO Driver\");"
    ],
    "description": "Linux GPIO platform driver skeleton"
  },

